---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CallToAction from '../components/CallToAction.astro';
---

<BaseLayout title="About Us | AAYRONIX HUB">
  <Header />
  <!-- Hero Section -->
  <section class="about-hero text-center">
    <!-- Watermark Logo -->
    <img src="/aayronix_logo.png" alt="" class="hero-watermark" id="heroWatermark" aria-hidden="true" />
    <div class="container animate-fade-in" style="position: relative; z-index: 2;">
      <span class="badge">Welcome to <span class="brand-gold">AAYRON</span><span class="brand-grey">IX HUB</span></span>
      <h1 class="title">Delivering Real Impact Through <span class="text-gradient">Talent & Technology</span></h1>
      <p class="subtitle">With over 30 years of combined experience, our founders lead AAYRONIX HUB in delivering scalable solutions. We help businesses innovate and stay ahead because we understand the pulse and needs of today’s organizations.</p>
    </div>
  </section>

  <!-- About and Vision Grid -->
  <section class="section">
    <div class="container about-grid">
      <div class="glass padding-box animate-fade-in" style="animation-delay: 0.1s;">
        <h2 style="margin-bottom: var(--spacing-4)">About Us</h2>
        <p>AAYRONIX HUB is a forward-thinking technology and talent partner specializing in ERP implementation, data analytics, cybersecurity, and AI/GenAI. We blend deep technical expertise with practical business insight to help organizations modernize their systems, unlock the full value of their data, and build secure, intelligent digital ecosystems.</p>
        <br>
        <p>As an IT consultancy and staffing partner, we deliver contingent and permanent workforce solutions backed by strategic advisory services. Our hallmark is hassle-free talent delivery—building scalable teams that accelerate growth through targeted workforce augmentation. Beyond recruitment, we architect and implement tailored software and IT solutions, from ERP and data platforms to AI-driven automation. By blending creativity with cutting-edge technology and robust cybersecurity, we empower businesses to achieve operational excellence, better decisions, and a lasting competitive advantage.</p>
      </div>

      <div class="about-image-wrapper animate-fade-in" style="animation-delay: 0.2s; height: 100%;">
         <img src="/corporate_about.png" alt="AAYRONIX HUB Corporate Team" style="border-radius: var(--radius-lg); width: 100%; height: 100%; object-fit: cover; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);" />
      </div>

      <div class="glass padding-box gradient-border animate-fade-in" style="animation-delay: 0.3s; grid-column: 1 / -1; margin-top: var(--spacing-4);">
        <h2 style="margin-bottom: var(--spacing-4)">Our Vision</h2>
        <p class="lead-text">"To be a trusted partner for enterprises by delivering world-class staffing solutions and innovative IT services, enabling sustainable growth and digital transformation and building for the future."</p>
      </div>
    </div>
  </section>

  <!-- Core Differentiators & What Sets Us Apart -->
  <section class="section" style="background-image: linear-gradient(rgba(15, 23, 42, 0.7), rgba(15, 23, 42, 0.7)), url('/corporate_bg.png?t=777'); background-size: cover; background-position: center; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--spacing-16)">
        <h2>What Sets Us Apart</h2>
        <p style="color: var(--color-text-muted); max-width: 700px; margin: 0 auto;">AAYRONIX HUB specializes in ERP, cloud, cyber security, data analytics, and AI/GenAI solutions with elite strategic advisory support.</p>
      </div>

      <div class="differentiators-grid">
        <div class="diff-card">
          <h4>Tailored Solutions</h4>
          <p>Personalized strategies aligned with your long-term vision.</p>
        </div>
        <div class="diff-card">
          <h4>Innovation-Driven</h4>
          <p>Expertise in AI, cloud, cybersecurity, and digital workplace solutions.</p>
        </div>
        <div class="diff-card">
          <h4>Proven Experience</h4>
          <p>Decades of success across industries, from startups to Fortune 500.</p>
        </div>
        <div class="diff-card">
          <h4>End-to-End Services</h4>
          <p>From advisory and implementation to managed services and recruitment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Divisions -->
  <section class="section">
    <div class="container text-center">
      <h2 style="margin-bottom: var(--spacing-12)">Our Divisions</h2>
      
      <div class="divisions-grid">
        <div class="division-card glass animate-fade-in" style="animation-delay: 0.1s;">
          <h3 class="text-gradient"><span class="brand-gold">AAYRON</span><span class="brand-grey">IX HUB</span> Digital</h3>
          <p>Mobile-first and cloud-first solutions built on emerging technologies.</p>
        </div>
        
        <div class="division-card glass animate-fade-in" style="animation-delay: 0.2s;">
          <h3 class="text-gradient"><span class="brand-gold">AAYRON</span><span class="brand-grey">IX HUB</span> Security</h3>
          <p>Multi-layered cybersecurity strategies to protect your business.</p>
        </div>

        <div class="division-card glass animate-fade-in" style="animation-delay: 0.3s;">
          <h3 class="text-gradient"><span class="brand-gold">AAYRON</span><span class="brand-grey">IX HUB</span> Talent</h3>
          <p>Recruitment and staffing solutions to build the leadership and teams you need.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contractor Care Highlight -->
  <section class="section container">
    <div class="contractor-care-banner glass pattern-bg split-banner">
      <div class="cc-image animate-fade-in" style="animation-delay: 0.1s;">
        <img src="/contractor_handshake_faces.png?v=1" alt="Trusted Contractor Partnership" />
      </div>
      <div class="cc-content animate-fade-in" style="animation-delay: 0.2s;">
        <h2><span class="brand-gold">AAYRON</span><span class="brand-grey">IX HUB</span><br><span class="text-gradient">Contractor Care</span></h2>
        <p>We treat our talent as partners. With 25+ years of experience supporting contractors across industries, we have a proven track record in reducing turnover rates using a personalized, relationship-driven approach.</p>
        <div class="trust-badge">
           <strong>Trusted partner for startups, mid-market, and Fortune 100 companies.</strong>
        </div>
        <a href="/contact" class="btn btn-primary" style="margin-top: var(--spacing-6);">Partner With Us For Success</a>
      </div>
    </div>
  </section>

  <CallToAction />
<Footer />
</BaseLayout>

<style>
  .text-center {
    text-align: center;
  }

  .about-hero {
    padding-top: 160px;
    padding-bottom: var(--spacing-16);
    position: relative;
    overflow: hidden;
  }

  .hero-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 420px;
    height: auto;
    opacity: 0.12;
    pointer-events: none;
    z-index: 1;
    transition: none; /* JS handles animation via requestAnimationFrame */
    filter: grayscale(30%) brightness(1.2);
  }

  .title {
    font-size: clamp(2.5rem, 4vw, 4rem);
    margin-bottom: var(--spacing-6);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .brand-gold {
    display: inline-block;
    background: linear-gradient(135deg, #D4A017 0%, #F5C842 40%, #E8B923 60%, #C8921A 100%) !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
    background-clip: text !important;
    color: #D4A017 !important;
    font-weight: 800;
  }

  .brand-grey {
    display: inline-block;
    color: #cbd5e1 !important;
    -webkit-text-fill-color: #cbd5e1 !important;
    font-weight: 800;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(212, 160, 23, 0.1);
    color: var(--color-primary);
    border-radius: var(--radius-full);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: var(--spacing-6);
    border: 1px solid rgba(212, 160, 23, 0.2);
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 800px;
    margin: 0 auto;
    text-align: justify;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 2fr 1.2fr;
    gap: var(--spacing-8);
  }

  .padding-box {
    padding: var(--spacing-12);
    border-radius: var(--radius-lg);
  }

  .padding-box p {
    color: var(--color-text-muted);
    text-align: justify;
  }

  .lead-text {
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 500;
    color: var(--color-text) !important;
    line-height: 1.4;
  }

  .gradient-border {
    position: relative;
  }

  .gradient-border::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: var(--radius-lg);
    border: 2px solid transparent;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent)) border-box;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    pointer-events: none;
  }

  .differentiators-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-8);
  }

  .diff-card {
    background: rgba(15, 23, 42, 0.5);
    padding: var(--spacing-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    transition: var(--transition);
  }

  .diff-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-5px);
  }

  .diff-card h4 {
    margin-bottom: var(--spacing-2);
    color: var(--color-text);
  }

  .diff-card p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .divisions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--spacing-8);
  }

  .division-card {
    padding: var(--spacing-12) var(--spacing-6);
    border-radius: var(--radius-lg);
  }

  .division-card h3 {
    margin-bottom: var(--spacing-4);
  }

  .division-card p {
    color: var(--color-text-muted);
  }

  .contractor-care-banner {
    border-radius: var(--radius-lg);
    position: relative;
    overflow: hidden;
    background: rgba(30, 41, 59, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);
  }

  .split-banner {
    display: flex;
    flex-direction: row;
    gap: var(--spacing-16);
    align-items: stretch;
    padding: var(--spacing-16);
  }

  .cc-image {
    flex: 1;
    position: relative;
    min-height: 350px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    z-index: 2;
  }

  .cc-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .trust-badge {
    margin-top: var(--spacing-6);
    padding: var(--spacing-4) var(--spacing-6);
    background: rgba(110, 231, 183, 0.1);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .pattern-bg::before {
    content: '';
    position: absolute;
    top: -50px;
    right: -50px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, var(--color-accent) 0%, transparent 60%);
    opacity: 0.15;
    border-radius: 50%;
  }

  .cc-content {
    flex: 1.2;
    text-align: left;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .cc-content p {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .about-grid, .divisions-grid {
      grid-template-columns: 1fr;
    }
    .split-banner {
      flex-direction: column;
      padding: var(--spacing-8);
      gap: var(--spacing-8);
    }
    .cc-image {
      width: 100%;
      min-height: 250px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const watermark = document.getElementById('heroWatermark');
    const headerLogo = document.querySelector('.header .brand-logo');
    if (!watermark || !headerLogo) return;

    // Store initial watermark position (center of hero)
    const heroSection = watermark.closest('.about-hero');
    const initialSize = 420; // matches CSS width
    const initialOpacity = 0.12;

    function lerp(start, end, t) {
      return start + (end - start) * t;
    }

    function animateWatermark() {
      const heroRect = heroSection.getBoundingClientRect();
      const headerLogoRect = headerLogo.getBoundingClientRect();

      // Calculate scroll progress within the hero section
      // 0 = hero fully visible, 1 = hero scrolled past
      const heroHeight = heroRect.height;
      const scrolled = Math.max(0, -heroRect.top);
      const progress = Math.min(1, scrolled / (heroHeight * 0.7));

      if (progress <= 0) {
        // Reset to initial centered watermark state
        watermark.style.position = 'absolute';
        watermark.style.top = '50%';
        watermark.style.left = '50%';
        watermark.style.transform = 'translate(-50%, -50%)';
        watermark.style.width = initialSize + 'px';
        watermark.style.opacity = initialOpacity;
        watermark.style.filter = 'grayscale(30%) brightness(1.2)';
        return;
      }

      // Target: header logo position
      const targetWidth = headerLogoRect.width;
      const targetOpacity = 0;

      // Calculate current watermark center in viewport
      const heroCenter = {
        x: heroRect.left + heroRect.width / 2,
        y: heroRect.top + heroRect.height / 2
      };

      // Target center (header logo center)
      const targetCenter = {
        x: headerLogoRect.left + headerLogoRect.width / 2,
        y: headerLogoRect.top + headerLogoRect.height / 2
      };

      // Ease function for smooth deceleration
      const eased = 1 - Math.pow(1 - progress, 3);

      // Interpolate size
      const currentWidth = lerp(initialSize, targetWidth, eased);

      // Interpolate position offset from center
      const offsetX = lerp(0, targetCenter.x - heroCenter.x, eased);
      const offsetY = lerp(0, targetCenter.y - heroCenter.y, eased);

      // Opacity: stay dark, just fade out smoothly as it goes up
      const currentOpacity = lerp(initialOpacity, 0, eased);

      watermark.style.position = 'absolute';
      watermark.style.top = '50%';
      watermark.style.left = '50%';
      watermark.style.transform = `translate(calc(-50% + ${offsetX}px), calc(-50% + ${offsetY}px))`;
      watermark.style.width = currentWidth + 'px';
      watermark.style.opacity = currentOpacity;
    }

    // Run on scroll with requestAnimationFrame for smoothness
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          animateWatermark();
          ticking = false;
        });
        ticking = true;
      }
    });

    // Initial call
    animateWatermark();
  });
</script>
