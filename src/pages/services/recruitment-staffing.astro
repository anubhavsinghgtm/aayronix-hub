---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';

const features = [
  {
    title: "Executive Search",
    list: [
      "Decades of experience in executive recruitment.",
      "In-depth cultural and mindset fit analysis.",
      "Attractive compensation package design.",
      "Rigorous screening, interviews, and reference checks."
    ]
  },
  {
    title: "Staff Augmentation",
    list: [
      "Contract, Contract-to-Hire, Direct Hire, Subcontracting, SOW.",
      "Access to global IT talent (Java, Python, AWS, SAP, etc.).",
      "Rapid ramp-up to meet deadlines.",
      "Reduced recruiting costs and liabilities."
    ]
  },
  {
    title: "Compliance & Transparency",
    list: [
      "Hassle-free documentation and compliance management.",
      "Rate verification and transparent billing processes.",
      "Adherence to local and international labor regulations.",
      "Ongoing support to ensure smooth operations."
    ]
  },
  {
    title: "Project-Based Staffing",
    list: [
      "Dedicated teams assembled for specific initiatives.",
      "Agile staffing models to scale quickly.",
      "Expertise in cloud, AI, cybersecurity, and digital transformation.",
      "Seamless integration with client workflows."
    ]
  },
  {
    title: "Specialized Skill Recruitment",
    list: [
      "IT, cloud, AI, cybersecurity, and engineering experts on demand.",
      "Talent matched precisely to project requirements.",
      "Global reach to source talent beyond local markets.",
      "Rigorous screening to ensure quality and expertise."
    ]
  },
  {
    title: "Recruitment Process Support",
    list: [
      "Resume screening and candidate shortlisting.",
      "Interview scheduling and coordination.",
      "Background checks and credential verification.",
      "Onboarding support for smooth transitions."
    ]
  },
  {
    title: "Payroll Services",
    list: [
      "Weekly payroll with custom online portal.",
      "Vacation & holiday pay, medical, vision & dental coverage.",
      "ACA-compliant contributory plans.",
      "Quick onboarding & scalable solutions."
    ]
  },
  {
    title: "Why Choose AAYRONIX HUB",
    list: [
      "Proven expertise in global talent acquisition.",
      "Flexible models for temporary, permanent, and project staffing.",
      "Reduced hiring costs and faster turnaround times.",
      "Trusted partner for startups, mid-market, and Fortune 100 companies."
    ]
  }
];
---

<BaseLayout title="Recruitment & Staffing | AAYRONIX HUB">
  <Header />
  <ParticleBackground particleColor="rgba(245, 158, 11, 0.8)" lineColor="rgba(245, 158, 11, 0.4)" interactiveColor="rgba(251, 146, 60, 1)" fullPage />
  <!-- Hero Section -->
  <section class="page-hero text-center" style="position: relative; padding-top: 180px; padding-bottom: 80px; overflow: hidden;">
    <div class="container animate-fade-in" style="position: relative; z-index: 2;">
      <span class="badge">Talent Solutions</span>
      <h1 class="title text-gradient">Recruitment & Staffing</h1>
      <p class="subtitle" style="color: rgba(255, 255, 255, 0.85); text-shadow: 0 2px 4px rgba(0,0,0,0.5);">Connecting Businesses with the Right Talent. Finding the right people at the right time is critical for growth. We provide flexible staffing and recruitment solutions designed to meet immediate needs, long-term goals, and specialized skill requirements. Whether you need one expert or a full team, we deliver talent that fits.</p>
    </div>
  </section>

  <!-- Details Grid -->
  <section class="section" style="margin-top: 5rem;">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--spacing-12)">
        <h2>Comprehensive Recruitment Options</h2>
        <p style="color: var(--color-text-muted);">Proven expertise in global talent acquisition across temporary, permanent, and project staffing.</p>
      </div>
      
      <div class="details-grid">
        {features.map((feature, idx) => (
          <div class="details-card glass animate-fade-in" style={`animation-delay: ${idx * 0.1}s`}>
            <h3>{feature.title}</h3>
            <ul class="custom-list">
              {feature.list.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CallToAction />
<Footer />
</BaseLayout>

<style>
  .text-center { text-align: center; }
  .page-hero { padding-top: 160px; padding-bottom: var(--spacing-16); }
  .badge { display: inline-block; padding: 0.25rem 0.75rem; background: rgba(110, 231, 183, 0.1); color: var(--color-accent); border-radius: var(--radius-full); font-size: 0.875rem; font-weight: 600; margin-bottom: var(--spacing-6); }
  .title { font-size: clamp(2.5rem, 4vw, 4rem); margin-bottom: var(--spacing-4); }
  .text-gradient { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { font-size: 1.25rem; max-width: 800px; margin: 0 auto; color: var(--color-text-muted); }
  .details-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: var(--spacing-8); }
  .details-card { padding: var(--spacing-8); border-radius: var(--radius-lg); border-top: 4px solid var(--color-primary); transition: var(--transition); }
  .details-card:hover { transform: translateY(-5px); border-color: var(--color-accent); }
  .details-card h3 { margin-bottom: var(--spacing-6); color: var(--color-text); }
  .custom-list { list-style: none; padding: 0; margin: 0; }
  .custom-list li { position: relative; padding-left: 1.5rem; margin-bottom: 0.75rem; color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.5; }
  .custom-list li::before { content: '→'; position: absolute; left: 0; color: var(--color-primary); font-weight: 600; }
</style>
