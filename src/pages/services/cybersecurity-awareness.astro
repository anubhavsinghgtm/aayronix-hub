---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';

const features = [
  {
    title: "Phishing Simulations",
    list: [
      "Real-world phishing scenarios to test employee responses.",
      "Safe, controlled exercises to identify vulnerabilities.",
      "Immediate feedback and coaching for improvement.",
      "Reduced risk of successful phishing attacks."
    ]
  },
  {
    title: "Employee Education",
    list: [
      "Customized training modules tailored to your industry.",
      "Easy-to-understand lessons on common cyber threats.",
      "Role-based training for executives, IT staff, and general employees.",
      "Ongoing education to keep pace with evolving risks."
    ]
  },
  {
    title: "Culture of Security",
    list: [
      "Build a security-first mindset across the organization.",
      "Encourage proactive reporting of suspicious activity.",
      "Reinforce best practices through regular communication.",
      "Create accountability and shared responsibility for cybersecurity."
    ]
  },
  {
    title: "Interactive Learning Tools",
    list: [
      "Gamified training modules to boost engagement.",
      "Quizzes and assessments to measure knowledge retention.",
      "Scenario-based exercises for practical application.",
      "Progress tracking and reporting for management."
    ]
  },
  {
    title: "Benefits of Awareness Training",
    list: [
      "Reduced risk of human error in cyber incidents.",
      "Improved compliance with industry regulations (GDPR, HIPAA, SOC 2).",
      "Stronger defense against phishing, ransomware, and social engineering.",
      "Increased employee confidence in handling digital threats."
    ]
  },
  {
    title: "Why Choose AAYRONIX HUB",
    list: [
      "Decades of experience in cybersecurity and compliance.",
      "Proven success in training teams across startups, mid-market, and Fortune 100 companies.",
      "Tailored programs aligned with organizational goals.",
      "Ongoing support to maintain a culture of security."
    ]
  }
];
---

<BaseLayout title="Cybersecurity Awareness Training | AAYRONIX HUB">
  <Header />
  <ParticleBackground particleColor="rgba(16, 185, 129, 0.8)" lineColor="rgba(16, 185, 129, 0.4)" interactiveColor="rgba(52, 211, 153, 1)" fullPage />
  <!-- Hero Section -->
  <section class="page-hero text-center" style="position: relative; padding-top: 180px; padding-bottom: 80px; overflow: hidden;">
    <div class="container animate-fade-in" style="position: relative; z-index: 2;">
      <span class="badge">Cybersecurity Training</span>
      <h1 class="title text-gradient">Cybersecurity Awareness Training</h1>
      <p class="subtitle" style="color: rgba(255, 255, 255, 0.85); text-shadow: 0 2px 4px rgba(0,0,0,0.5);">Empower Your Workforce to Be the First Line of Defense. Technology alone cannot stop cyber threats—your employees play a critical role. We provide comprehensive cybersecurity awareness training programs that educate, engage, and empower your workforce to recognize and prevent attacks before they happen.</p>
    </div>
  </section>

  <!-- Details Grid -->
  <section class="section" style="margin-top: 5rem;">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--spacing-12)">
        <h2>Why Choose AAYRONIX HUB</h2>
        <p style="color: var(--color-text-muted);">Decades of experience with tailored programs aligned with organizational goals.</p>
      </div>
      
      <div class="details-grid">
        {features.map((feature, idx) => (
          <div class="details-card glass animate-fade-in" style={`animation-delay: ${idx * 0.1}s`}>
            <h3>{feature.title}</h3>
            <ul class="custom-list">
              {feature.list.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CallToAction />
<Footer />
</BaseLayout>

<style>
  .text-center { text-align: center; }
  .page-hero { padding-top: 160px; padding-bottom: var(--spacing-16); }
  .badge { display: inline-block; padding: 0.25rem 0.75rem; background: rgba(110, 231, 183, 0.1); color: var(--color-accent); border-radius: var(--radius-full); font-size: 0.875rem; font-weight: 600; margin-bottom: var(--spacing-6); }
  .title { font-size: clamp(2.5rem, 4vw, 4rem); margin-bottom: var(--spacing-4); }
  .text-gradient { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { font-size: 1.25rem; max-width: 800px; margin: 0 auto; color: var(--color-text-muted); }
  .details-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: var(--spacing-8); }
  .details-card { padding: var(--spacing-8); border-radius: var(--radius-lg); border-top: 4px solid var(--color-primary); transition: var(--transition); }
  .details-card:hover { transform: translateY(-5px); border-color: var(--color-accent); }
  .details-card h3 { margin-bottom: var(--spacing-6); color: var(--color-text); }
  .custom-list { list-style: none; padding: 0; margin: 0; }
  .custom-list li { position: relative; padding-left: 1.5rem; margin-bottom: 0.75rem; color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.5; }
  .custom-list li::before { content: '→'; position: absolute; left: 0; color: var(--color-primary); font-weight: 600; }
</style>
