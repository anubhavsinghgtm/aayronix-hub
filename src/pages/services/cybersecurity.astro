---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';

const features = [
  {
    title: "Threat Detection & Response",
    list: [
      "Continuous monitoring of networks, applications, and endpoints.",
      "Real-time identification of vulnerabilities and suspicious activity.",
      "Rapid incident response to minimize downtime and damage."
    ]
  },
  {
    title: "Compliance & Risk Management",
    list: [
      "Governance, Risk, and Compliance (GRC) frameworks.",
      "Regulatory compliance support (GDPR, HIPAA, ISO, SOC 2).",
      "Risk assessments to identify and mitigate potential threats."
    ]
  },
  {
    title: "Endpoint Protection",
    list: [
      "Advanced antivirus and anti-malware solutions.",
      "Device-level encryption and access control.",
      "Secure mobile workforce solutions."
    ]
  },
  {
    title: "App & Infrastructure Security",
    list: [
      "Vulnerability and penetration testing.",
      "System software security assessments.",
      "Client-side and server-side application protection.",
      "Disaster recovery planning."
    ]
  },
  {
    title: "Security Awareness Training",
    list: [
      "Real-world phishing scenarios to test employee responses.",
      "Customized training modules tailored to your industry.",
      "Ongoing education to keep pace with evolving risks."
    ]
  },
  {
    title: "Why Choose AAYRONIX HUB",
    list: [
      "Decades of experience securing enterprises worldwide.",
      "Multi-layered protection strategies customized to your needs.",
      "24/7/365 monitoring and support from seasoned experts.",
      "Proven track record with Fortune 100 companies."
    ]
  }
];
---

<BaseLayout title="Cybersecurity | AAYRONIX HUB">
  <Header />
  <ParticleBackground particleColor="rgba(6, 182, 212, 0.8)" lineColor="rgba(6, 182, 212, 0.4)" interactiveColor="rgba(16, 185, 129, 1)" fullPage />
  <!-- Hero Section -->
  <section class="page-hero text-center" style="position: relative; padding-top: 180px; padding-bottom: 80px; overflow: hidden;">
    <div class="container animate-fade-in" style="position: relative; z-index: 2;">
      <span class="badge">Security</span>
      <h1 class="title text-gradient">Cybersecurity Solutions</h1>
      <p class="subtitle" style="color: rgba(255, 255, 255, 0.85); text-shadow: 0 2px 4px rgba(0,0,0,0.5);"><strong style="display: block; margin-bottom: 0.5rem; text-align: center;">Stop Cyber-Attacks Before They Stop You.</strong>In today’s digital-first world, cyber threats are more sophisticated than ever. We deliver end-to-end cybersecurity solutions that protect your networks, applications, and data—keeping your business secure, compliant, and resilient.</p>
    </div>
  </section>

  <!-- Details Grid -->
  <section class="section" style="margin-top: 5rem;">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--spacing-12)">
        <h2>Multi-Layered Protection</h2>
        <p style="color: var(--color-text-muted); text-align: center; max-width: 800px; margin: 0 auto;">Decades of experience securing enterprises worldwide with 24/7/365 monitoring.</p>
      </div>
      
      <div class="details-grid">
        {features.map((feature, idx) => (
          <div class="details-card glass animate-fade-in" style={`animation-delay: ${idx * 0.1}s`}>
            <h3>{feature.title}</h3>
            <ul class="custom-list">
              {feature.list.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CallToAction />
<Footer />
</BaseLayout>

<style>
  .text-center { text-align: center; }
  .page-hero { padding-top: 160px; padding-bottom: var(--spacing-16); }
  .badge { display: inline-block; padding: 0.5rem 1rem; background: rgba(110, 231, 183, 0.1); color: var(--color-accent); border-radius: var(--radius-full); font-size: 1.125rem; font-weight: 700; margin-bottom: var(--spacing-6); }
  .title { font-size: clamp(2.5rem, 4vw, 4rem); margin-bottom: var(--spacing-4); }
  .text-gradient { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { font-size: 1.25rem; max-width: 800px; margin: 0 auto; color: var(--color-text-muted); text-align: justify; }
  .details-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: var(--spacing-8); }
  .details-card { padding: var(--spacing-8); border-radius: var(--radius-lg); border-top: 4px solid var(--color-primary); transition: var(--transition); }
  .details-card:hover { transform: translateY(-5px); border-color: var(--color-accent); }
  .details-card h3 { margin-bottom: var(--spacing-6); color: var(--color-text); }
  .custom-list { list-style: none; padding: 0; margin: 0; }
  .custom-list li { position: relative; padding-left: 1.5rem; margin-bottom: 0.75rem; color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.5; }
  .custom-list li::before { content: '→'; position: absolute; left: 0; color: var(--color-primary); font-weight: 600; }
</style>
