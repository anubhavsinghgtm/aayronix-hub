---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';

const features = [
  {
    title: "Project-Specific Hiring",
    list: [
      "Rapid deployment of specialized recruiters.",
      "Short-term hiring campaigns for urgent requirements.",
      "Scalable solutions for seasonal or project-based demands."
    ]
  },
  {
    title: "Client-Branded Media Strategies",
    list: [
      "Employer branding campaigns to attract top candidates.",
      "Customized recruitment marketing aligned with your brand voice.",
      "Social media and digital outreach strategies."
    ]
  },
  {
    title: "Dedicated Recruitment Staff",
    list: [
      "Full-cycle recruitment management.",
      "Candidate sourcing, screening, and interviewing.",
      "Seamless integration with your internal HR processes."
    ]
  },
  {
    title: "Full or Partial HR Management",
    list: [
      "End-to-end recruitment lifecycle management.",
      "Partial outsourcing for specific functions (screening, onboarding, etc.).",
      "Flexible engagement models to optimize recruitment costs."
    ]
  },
  {
    title: "Contractor Care & Retention",
    list: [
      "Open communication between contractors, employers, and Aayronix Hub.",
      "Regular check-ins and opportunities for feedback and social events.",
      "Data-driven insights for smarter hiring decisions."
    ]
  },
  {
    title: "Hassle-Free Solutions",
    list: [
      "Streamlined timecard and payroll processes.",
      "Quality benefits tailored to contractor needs.",
      "Reduced resource gaps and delivery pains.",
      "Improved productivity and cost controls."
    ]
  }
];
---

<BaseLayout title="RPO | Aayronix Hub">
  <Header />
  <ParticleBackground particleColor="rgba(249, 115, 22, 0.8)" lineColor="rgba(249, 115, 22, 0.4)" interactiveColor="rgba(253, 186, 116, 1)" fullPage />
  <!-- Hero Section -->
  <section class="page-hero text-center" style="position: relative; padding-top: 180px; padding-bottom: 80px; overflow: hidden;">
    <div class="container animate-fade-in" style="position: relative; z-index: 2;">
      <span class="badge">Talent Solutions</span>
      <h1 class="title text-gradient">Recruitment Process Outsourcing</h1>
      <p class="subtitle" style="color: rgba(255, 255, 255, 0.85); text-shadow: 0 2px 4px rgba(0,0,0,0.5);">Cost-Effective Recruiting Strategies. Today's talent market is unpredictable and competitive. Our RPO services provide the expertise, tools, and processes to attract, hire, and retain top talent—while saving you time and money.</p>
    </div>
  </section>

  <!-- Details Grid -->
  <section class="section" style="margin-top: 5rem;">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--spacing-12)">
        <h2>Why Outsource to Aayronix Hub</h2>
        <p style="color: var(--color-text-muted);">Reduce Turnover, Boost Productivity. We simplify contractor management so you can stay focused on your business.</p>
      </div>
      
      <div class="details-grid">
        {features.map((feature, idx) => (
          <div class="details-card glass animate-fade-in" style={`animation-delay: ${idx * 0.1}s`}>
            <h3>{feature.title}</h3>
            <ul class="custom-list">
              {feature.list.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CallToAction />
<Footer />
</BaseLayout>

<style>
  .text-center { text-align: center; }
  .page-hero { padding-top: 160px; padding-bottom: var(--spacing-16); }
  .badge { display: inline-block; padding: 0.25rem 0.75rem; background: rgba(110, 231, 183, 0.1); color: var(--color-accent); border-radius: var(--radius-full); font-size: 0.875rem; font-weight: 600; margin-bottom: var(--spacing-6); }
  .title { font-size: clamp(2.5rem, 4vw, 4rem); margin-bottom: var(--spacing-4); }
  .text-gradient { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { font-size: 1.25rem; max-width: 800px; margin: 0 auto; color: var(--color-text-muted); }
  .details-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: var(--spacing-8); }
  .details-card { padding: var(--spacing-8); border-radius: var(--radius-lg); border-top: 4px solid var(--color-primary); transition: var(--transition); }
  .details-card:hover { transform: translateY(-5px); border-color: var(--color-accent); }
  .details-card h3 { margin-bottom: var(--spacing-6); color: var(--color-text); }
  .custom-list { list-style: none; padding: 0; margin: 0; }
  .custom-list li { position: relative; padding-left: 1.5rem; margin-bottom: 0.75rem; color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.5; }
  .custom-list li::before { content: '→'; position: absolute; left: 0; color: var(--color-primary); font-weight: 600; }
</style>
