---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServicesGrid from '../../components/Services.astro';
import CallToAction from '../../components/CallToAction.astro';
---

<BaseLayout title="Our Services | Aayronix Hub">
  <Header />
<!-- Coming Soon Snippet -->
  <div style="min-height: 60vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem;">
    <span style="display: inline-block; padding: 0.25rem 0.75rem; background: rgba(59, 130, 246, 0.1); color: #3b82f6; border-radius: 9999px; font-size: 0.875rem; font-weight: 600; margin-bottom: 1.5rem; border: 1px solid rgba(59, 130, 246, 0.2);">Work In Progress</span>
    <h1 style="font-size: clamp(2.5rem, 5vw, 4rem); margin-bottom: 1rem; background: linear-gradient(135deg, #3b82f6 0%, #10b981 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Coming Soon</h1>
    <p style="color: #94a3b8; font-size: 1.25rem; max-width: 600px; margin: 0 auto;">We are currently working hard to prepare this content. Please check back later.</p>
    <a href="/" style="display: inline-block; margin-top: 2rem; padding: 0.75rem 1.5rem; background: #3b82f6; color: white; text-decoration: none; border-radius: 0.375rem; font-weight: 500; transition: background 0.2s;">Back to Home</a>
  </div>

  {/*  


  <!-- Hero Section -->
  <section class="page-hero text-center" style="padding-top: 160px; padding-bottom: var(--spacing-8);">
    <div class="container animate-fade-in">
      <span class="badge">What We Do</span>
      <h1 class="title text-gradient">Solutions That Drive Growth</h1>
      <p class="subtitle" style="font-size: 1.25rem; max-width: 800px; margin: 0 auto;">From cloud transformation to complete IT recruitment, we provide end-to-end expertise to power your enterprise into the future.</p>
    </div>
  </section>

  <!-- We reuse the existing Services.astro component here -->
  <ServicesGrid />

  <CallToAction />
  
  */}
<Footer />
</BaseLayout>

<style>
  .text-center { text-align: center; }
  .badge { display: inline-block; padding: 0.25rem 0.75rem; background: rgba(110, 231, 183, 0.1); color: var(--color-accent); border-radius: var(--radius-full); font-size: 0.875rem; font-weight: 600; margin-bottom: var(--spacing-6); }
  .title { font-size: clamp(2.5rem, 4vw, 4rem); margin-bottom: var(--spacing-4); }
  .text-gradient { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { color: var(--color-text-muted); }
</style>
