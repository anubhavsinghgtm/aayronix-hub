---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';

const features = [
  {
    title: "Flexible Engagement Models",
    list: [
      "Contract: Short-term specialists for immediate projects.",
      "Contract-to-Hire: Evaluate talent before making permanent hires.",
      "Direct Placement: Full-time employees sourced and vetted by our experts.",
      "Subcontracting: Expand your delivery capacity with trusted professionals.",
      "Statement of Work (SOW): Project-based engagements with defined deliverables."
    ]
  },
  {
    title: "Access to Expertise",
    list: [
      "Application Development.",
      "Cloud & Infrastructure.",
      "Cybersecurity & Compliance.",
      "Big Data & Analytics.",
      "Agile, Scrum, and DevOps practices.",
      "Database and Application Modernisation."
    ]
  },
  {
    title: "Benefits of Staff Augmentation",
    list: [
      "Rapid ramp-up to meet aggressive deadlines.",
      "Reduced recruiting costs and liabilities.",
      "Higher efficiency of existing staff and processes.",
      "Compliance with industry standards and regulations.",
      "Access to global talent pool across multiple technologies."
    ]
  },
  {
    title: "Quality Processes & Retention",
    list: [
      "Rigorous candidate coverage and quality control.",
      "Employee experience and retention programs.",
      "Global account and delivery teams for seamless support.",
      "Onsite and remote delivery options."
    ]
  },
  {
    title: "Why Choose AAYRONIX HUB",
    list: [
      "30+ years of experience serving startups, mid-market, and Fortune 100 companies.",
      "Flexible staffing solutions tailored to your needs.",
      "Proven track record in digital transformation, AI, and cybersecurity projects.",
      "Commitment to quality, retention, and compliance."
    ]
  }
];
---

<BaseLayout title="Staff Augmentation | AAYRONIX HUB">
  <Header />
  <ParticleBackground particleColor="rgba(250, 204, 21, 0.8)" lineColor="rgba(250, 204, 21, 0.4)" interactiveColor="rgba(253, 224, 71, 1)" fullPage />
  <!-- Hero Section -->
  <section class="page-hero text-center" style="position: relative; padding-top: 180px; padding-bottom: 80px; overflow: hidden;">
    <div class="container animate-fade-in" style="position: relative; z-index: 2;">
      <span class="badge">Talent Solutions</span>
      <h1 class="title text-gradient">Staff Augmentation</h1>
      <p class="subtitle" style="color: rgba(255, 255, 255, 0.85); text-shadow: 0 2px 4px rgba(0,0,0,0.5);"><strong style="display: block; margin-bottom: 0.5rem; text-align: center;">Organisational Agility, Lower Cost, Expanded Expertise.</strong>Sometimes you don’t need outsourcing—you need reinforcements. Our staff augmentation services embed highly skilled professionals directly into your teams, giving you the flexibility to scale resources and accelerate delivery without the overhead of permanent hiring.</p>
    </div>
  </section>

  <!-- Details Grid -->
  <section class="section" style="margin-top: 5rem;">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--spacing-12)">
        <h2>Our Augmentation Steps</h2>
        <p style="color: var(--color-text-muted); text-align: center; max-width: 800px; margin: 0 auto;">Serving startups, mid-market, and Fortune 100 companies with tailored staffing solutions.</p>
      </div>
      
      <div class="details-grid">
        {features.map((feature, idx) => (
          <div class="details-card glass animate-fade-in" style={`animation-delay: ${idx * 0.1}s`}>
            <h3>{feature.title}</h3>
            <ul class="custom-list">
              {feature.list.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CallToAction />
<Footer />
</BaseLayout>

<style>
  .text-center { text-align: center; }
  .page-hero { padding-top: 160px; padding-bottom: var(--spacing-16); }
  .badge { display: inline-block; padding: 0.5rem 1rem; background: rgba(110, 231, 183, 0.1); color: var(--color-accent); border-radius: var(--radius-full); font-size: 1.125rem; font-weight: 700; margin-bottom: var(--spacing-6); }
  .title { font-size: clamp(2.5rem, 4vw, 4rem); margin-bottom: var(--spacing-4); }
  .text-gradient { background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .subtitle { font-size: 1.25rem; max-width: 800px; margin: 0 auto; color: var(--color-text-muted); text-align: justify; }
  .details-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: var(--spacing-8); }
  .details-card { padding: var(--spacing-8); border-radius: var(--radius-lg); border-top: 4px solid var(--color-primary); transition: var(--transition); }
  .details-card:hover { transform: translateY(-5px); border-color: var(--color-accent); }
  .details-card h3 { margin-bottom: var(--spacing-6); color: var(--color-text); }
  .custom-list { list-style: none; padding: 0; margin: 0; }
  .custom-list li { position: relative; padding-left: 1.5rem; margin-bottom: 0.75rem; color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.5; }
  .custom-list li::before { content: '→'; position: absolute; left: 0; color: var(--color-primary); font-weight: 600; }
</style>
