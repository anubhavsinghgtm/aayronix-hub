<style>
  .contact-page {
    padding-top: 160px; /* offset for fixed header */
    padding-bottom: var(--spacing-24);
    min-height: 80vh;
  }

  .text-center {
    text-align: center;
  }

  .contact-header {
    max-width: 700px;
    margin: 0 auto var(--spacing-16) auto;
  }

  .title {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    margin-bottom: var(--spacing-4);
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--spacing-8);
  }

  .contact-info, .contact-form-wrapper {
    padding: var(--spacing-8);
    border-radius: var(--radius-lg);
  }

  .contact-info h3 {
    margin-bottom: var(--spacing-4);
  }

  .contact-info p {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-8);
    font-size: 0.875rem;
  }

  .info-block {
    margin-bottom: var(--spacing-6);
  }

  .info-block strong {
    display: block;
    color: var(--color-text);
    margin-bottom: var(--spacing-1);
    font-size: 0.875rem;
  }

  .info-block a {
    color: var(--color-primary);
    font-size: 1rem;
    font-weight: 500;
  }

  .info-block a:hover {
    color: var(--color-accent);
  }

  /* Form Styling */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  input, select, textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    background: rgba(15, 23, 42, 0.5); /* darker inputs inside glass panel */
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: var(--transition);
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
  }

  /* Fix for select dropdown options defaulting to white in some browsers */
  select option {
    background-color: var(--color-surface);
    color: var(--color-text);
  }

  .submit-btn {
    width: 100%;
    padding: 1rem;
    font-size: 1.125rem;
    margin-top: var(--spacing-4);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
