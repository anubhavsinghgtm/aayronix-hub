---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact Us | AAYRONIX HUB">
  <Header />
  <main class="contact-page container">
    <div class="contact-header text-center animate-fade-in">
      <h1 class="title">Let's Build Success <span class="text-gradient">Together</span></h1>
      <p class="subtitle">Have a project in mind, need specialized talent, or want to explore our IT solutions? Drop us a message and our team will get back to you shortly.</p>
    </div>

    <div class="contact-grid">
      <!-- Contact Information Panel -->
      <div class="contact-info glass animate-fade-in" style="animation-delay: 0.2s">
        <h3>Reach Out Directly</h3>
        <p>If you prefer to email or call us directly, here is our contact information.</p>
        
        <div class="info-block">
          <strong>General Inquiries</strong>
          <a href="mailto:info@aayronixhub.com">info@aayronixhub.com</a>
        </div>

        <div class="info-block">
          <strong>Phone</strong>
          <a href="tel:+919705003177">+91 97050 03177</a>
        </div>

        <div class="info-block" style="margin-top: var(--spacing-8);">
          <a href="https://wa.me/919705003177" target="_blank" rel="noopener noreferrer" class="whatsapp-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
              <path d="M12.031 0C5.385 0 .001 5.384.001 12.032c0 2.122.554 4.195 1.605 6.012L.037 24l6.115-1.603c1.748.956 3.729 1.46 5.877 1.46h.005c6.645 0 12.029-5.384 12.029-12.031C24.062 5.385 18.675 0 12.031 0zm0 21.849c-1.802 0-3.565-.483-5.111-1.401l-.367-.217-3.799 1.002.998-3.715-.238-.379c-1.008-1.603-1.542-3.468-1.542-5.405 0-5.592 4.549-10.141 10.142-10.141 5.591 0 10.14 4.55 10.14 10.142s-4.549 10.114-10.142 10.114zm5.556-7.593c-.305-.152-1.802-.89-2.083-.991-.281-.102-.485-.152-.69.152-.204.305-.79 1.02-.968 1.224-.179.204-.356.23-.661.077-1.834-.91-3.149-1.956-4.328-3.953-.205-.347.167-.323.754-1.493.102-.204.051-.382-.026-.534-.076-.153-.689-1.658-.944-2.271-.248-.596-.5-.515-.689-.525-.179-.009-.383-.009-.587-.009-.204 0-.535.076-.815.382-.281.305-1.07 1.045-1.07 2.545 0 1.5.156 2.951.258 3.093s2.107 3.238 5.105 4.532c.713.308 1.269.492 1.703.629.715.228 1.365.195 1.881.118.577-.085 1.802-.736 2.057-1.448.255-.713.255-1.32.179-1.448-.077-.128-.282-.204-.587-.356z"/>
            </svg>
            Message on WhatsApp
          </a>
        </div>
        <div class="info-block" style="margin-top: var(--spacing-8);">
          <strong>Address</strong>
          <span style="color: var(--color-text-muted); font-size: 0.875rem;">Gachibowli, Hyderabad, India</span>
        </div>

        <div style="margin-top: var(--spacing-4); border-radius: var(--radius-md); overflow: hidden; height: 250px;">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d121825.26384260388!2d78.27138090288869!3d17.43329971932356!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bcb93a2eb630b91%3A0xb36a0fbacd5ec874!2sGachibowli%2C%20Hyderabad%2C%20Telangana!5e0!3m2!1sen!2sin!4v1700000000000!5m2!1sen!2sin" 
            width="100%" 
            height="100%" 
            style="border:0; filter: invert(90%) hue-rotate(180deg);" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>

      <!-- Contact Form Panel -->
      <div class="contact-form-wrapper glass animate-fade-in" style="animation-delay: 0.3s">
        <form action="#" method="POST" enctype="multipart/form-data" class="contact-form">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" required placeholder="John Doe" />
          </div>

          <div class="form-group">
            <label for="email">Work Email</label>
            <input type="email" id="email" name="email" required placeholder="john@company.com" />
          </div>

          <div class="form-group">
            <label for="subject">Reason for Inquiry</label>
            <select id="subject" name="subject" required>
              <option value="" disabled selected>Select an option...</option>
              <option value="cloud">Cloud & Digital Transformation</option>
              <option value="cybersecurity">Cybersecurity Solutions</option>
              <option value="staffing">Staff Augmentation & RPO</option>
              <option value="ai">AI & Data Analytics</option>
              <option value="other">Other / General Inquiry</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Project Details</label>
            <textarea id="message" name="message" rows="5" required placeholder="Tell us about your goals..."></textarea>
          </div>

          <div class="form-group">
            <label for="resume">Attach Resume / Document <span style="color: var(--color-text-muted); font-weight: 400;">(optional)</span></label>
            <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx,.txt" class="file-input-themed" />
          </div>

          <button type="submit" class="btn btn-primary submit-btn">Send Message</button>
        </form>
      </div>
    </div>
  </main>
<Footer />
</BaseLayout>

<style>
  .contact-page {
    padding-top: 160px; /* offset for fixed header */
    padding-bottom: var(--spacing-24);
    min-height: 80vh;
  }

  .text-center {
    text-align: center;
  }

  .contact-header {
    max-width: 700px;
    margin: 0 auto var(--spacing-16) auto;
  }

  .title {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    margin-bottom: var(--spacing-4);
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--spacing-8);
  }

  .contact-info, .contact-form-wrapper {
    padding: var(--spacing-8);
    border-radius: var(--radius-lg);
  }

  .contact-info h3 {
    margin-bottom: var(--spacing-4);
  }

  .contact-info p {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-8);
    font-size: 0.875rem;
  }

  .info-block {
    margin-bottom: var(--spacing-6);
  }

  .info-block strong {
    display: block;
    color: var(--color-text);
    margin-bottom: var(--spacing-1);
    font-size: 0.875rem;
  }

  .info-block a {
    color: var(--color-primary);
    font-size: 1rem;
    font-weight: 500;
  }

  .info-block a:hover {
    color: var(--color-accent);
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background-color: #25d366;
    color: #ffffff !important;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 1rem;
    transition: var(--transition);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .whatsapp-btn:hover {
    background-color: #128c7e;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
  }

  /* Form Styling */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  input, select, textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    background: rgba(15, 23, 42, 0.5); /* darker inputs inside glass panel */
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: var(--transition);
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
  }

  /* Fix for select dropdown options defaulting to white in some browsers */
  select option {
    background-color: var(--color-surface);
    color: var(--color-text);
  }

  .submit-btn {
    width: 100%;
    padding: 1rem;
    font-size: 1.125rem;
    margin-top: var(--spacing-4);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  .file-input-themed {
    padding: 0.5rem; /* Adjust padding for the button inside */
  }

  .file-input-themed::file-selector-button {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    cursor: pointer;
    margin-right: 1rem;
    font-family: var(--font-body);
    transition: var(--transition);
  }

  .file-input-themed::file-selector-button:hover {
    background-color: var(--color-primary);
    color: #1a1a2e;
    border-color: var(--color-primary);
  }
</style>

