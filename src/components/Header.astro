---
// Header.astro
---

<!-- Independent Floating Logo -->
<a href="/" class="floating-logo" id="mainLogo">
  <img src="/aayronix_logo.png" alt="AAYRONIX HUB logo" class="brand-logo" />
</a>

<header class="header">
  <div class="container header-container">
    

    <nav class="nav-links">
      <a href="/">Home</a>
      <a href="/about">About Us</a>
      <div class="nav-dropdown">
        <a href="/services" class="dropdown-trigger">
          Services
          <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="dropdown-menu">
          <a href="/services/cloud-transformation">Cloud & Digital Transformation</a>
          <a href="/services/erp-implementation">ERP Implementation</a>
          <a href="/services/ai-innovation">Data Analytics & AI/Gen AI</a>
          <a href="/services/cybersecurity">Cybersecurity</a>
          <a href="/services/cybersecurity-awareness">Cybersecurity Awareness Training</a>
          <a href="/services/recruitment-staffing">Recruitment & Staffing</a>
          <a href="/services/staff-augmentation">Staff Augmentation</a>
          <a href="/services/rpo">Recruitment Process Outsourcing</a>
          <a href="/services/contractor-care">Contractor Care</a>
        </div>
      </div>
      <a href="/case-studies">Case Studies</a>
      <a href="/careers">Careers</a>
      <a href="/industries">Industries</a>
      <a href="/contact" class="btn btn-primary" style="padding: 0.5rem 1.5rem; font-size: 0.875rem;">Get in Touch</a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: var(--transition);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    height: 100px;
    position: relative;
  }

  .floating-logo {
    position: fixed;
    top: 15px;
    left: clamp(1rem, 5%, 3rem); /* Responsive left margin */
    z-index: 1000; /* Extremely high z-index to stay above everything */
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .floating-logo .brand-logo {
    height: 160px;
    width: auto;
    object-fit: contain;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5));
  }

  /* Scrolled State Triggered by Body Class or manually via JS */
  .floating-logo.scrolled {
    top: 12px;
  }

  .floating-logo.scrolled .brand-logo {
    height: 75px; /* Compact size to fit inside header */
    filter: none;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--spacing-6);
  }

  .nav-links > a:not(.btn),
  .dropdown-trigger {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: var(--transition);
  }

  .nav-links > a:not(.btn):hover,
  .dropdown-trigger:hover {
    color: var(--color-text);
  }

  /* Dropdown */
  .nav-dropdown {
    position: relative;
  }

  .dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
  }

  .dropdown-arrow {
    transition: transform 0.3s ease;
  }

  .nav-dropdown:hover .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 0.75rem;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    min-width: 210px;
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    z-index: 200;
  }

  .nav-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
  }

  .dropdown-menu a {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .dropdown-menu a:hover {
    color: var(--color-text);
  }

  @media (max-width: 1024px) {
    .nav-links {
      display: none; /* simple mobile setup for now */
    }
  }
</style>

<script>
  // Add scroll listener to shrink independent logo
  document.addEventListener('DOMContentLoaded', () => {
    const floatingLogo = document.getElementById('mainLogo');
    
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        if(floatingLogo) floatingLogo.classList.add('scrolled');
      } else {
        if(floatingLogo) floatingLogo.classList.remove('scrolled');
      }
    });

    // Run once on load
    if (window.scrollY > 50 && floatingLogo) {
      floatingLogo.classList.add('scrolled');
    }
  });
</script>
