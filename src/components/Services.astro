---

<section id="services" class="section services">
  <div class="container">
    <div class="section-header">
      <h2>Our Core Services</h2>
      <p>Delivering excellence through innovation, staffing and full-scale tech expertise.</p>
    </div>

    <div class="services-grid">
      {allServices.map((service, index) => (
        <a href={service.href} class="service-card glass animate-fade-in" style={`animation-delay: ${index * 0.15}s`}>
          <div class="icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
            </svg>
          </div>
          <h3>{service.title}</h3>
          <p>{service.desc}</p>
          <span class="learn-more">Explore Service →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    position: relative;
    background: transparent;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-16);
  }

  .section-header h2 {
    margin-bottom: var(--spacing-4);
  }

  .section-header p {
    color: var(--color-text-muted);
    font-size: 1.125rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-8);
  }

  .service-card {
    padding: var(--spacing-8);
    border-radius: var(--radius-lg);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .service-card:hover {
    transform: translateY(-10px);
    border-color: var(--color-primary);
    box-shadow: 0 10px 40px -10px rgba(59, 130, 246, 0.2);
  }

  .icon-wrapper {
    width: 60px;
    height: 60px;
    background: rgba(59, 130, 246, 0.1);
    color: var(--color-primary);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-6);
  }

  .icon-wrapper svg {
    width: 32px;
    height: 32px;
  }

  .service-card h3 {
    margin-bottom: var(--spacing-4);
    font-size: 1.5rem;
  }

  .service-card p {
    color: var(--color-text-muted);
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: var(--spacing-6);
  }

  .learn-more {
    font-weight: 600;
    color: var(--color-primary);
    font-size: 0.875rem;
    transition: var(--transition);
  }

  .service-card:hover .learn-more {
    color: var(--color-accent);
  }
</style>
