const allServices = [
  {
    title: "Cloud & Digital Transformation",
    desc: "Scale smarter with cloud-first strategies, advisory, and seamless digital workstation experiences.",
    href: "/services/cloud-transformation",
    icon: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"
  },
  {
    title: "Cybersecurity",
    desc: "Protect your business with proactive, multi-layered security strategies and threat detection.",
    href: "/services/cybersecurity",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
  },
  {
    title: "Data Analytics & AI/GenAI",
    desc: "Business intelligence, predictive analytics, and automated workflows to transform customer experience.",
    href: "/services/ai-innovation",
    icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
  },
  {
