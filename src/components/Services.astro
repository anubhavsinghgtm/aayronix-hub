    desc: "Protect your business with proactive, multi-layered security strategies and threat detection.",
    href: "/services/cybersecurity",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
  },
  {
    title: "Cybersecurity Awareness Training",
    desc: "Empower your workforce with phishing simulations, role-based education, and interactive learning tools.",
    href: "/services/cybersecurity-awareness",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
  },
