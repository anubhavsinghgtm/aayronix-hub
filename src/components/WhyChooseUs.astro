---
// WhyChooseUs.astro
const reasons = [
  {
    title: "Global Talent Network",
    desc: "Access skilled professionals worldwide",
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
  },
  {
    title: "Trusted Partners",
    desc: "Supporting businesses across industries",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
  },
  {
    title: "Tech Expertise",
    desc: "Proven solutions in cloud, AI, and cybersecurity",
    icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
  },
  {
    title: "Tailored Recruitment",
    desc: "Flexible solutions for teams of any size",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.956 11.956 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
  }
];
---

<section class="section why-choose-us" style="background-color: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <div class="container split-layout">
    
    <div class="grid-half">
      {reasons.map((reason, index) => (
        <div class="reason-card glass animate-fade-in" style={`animation-delay: ${index * 0.1}s`}>
          <div class="icon-orb">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={reason.icon} />
             </svg>
          </div>
          <h4>{reason.title}</h4>
          <p>{reason.desc}</p>
        </div>
      ))}
    </div>

    <div class="content-half">
      <h2>Why Choose Us</h2>
      <p class="lead" style="color: var(--color-text-muted); font-size: 1.125rem; margin-bottom: var(--spacing-8);">We deliver solutions that drive growth, innovation, and operational excellence for your organization.</p>
      
      <a href="/contact" class="btn btn-primary">Collaborate with Aayronix Hub →</a>
    </div>

  </div>
</section>

<style>
  .split-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--spacing-16);
    align-items: center;
  }

  .grid-half {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-6);
  }

  .content-half h2 {
    font-size: clamp(2rem, 3vw, 2.5rem);
    margin-bottom: var(--spacing-4);
  }

  .reason-card {
    padding: var(--spacing-6);
    border-radius: var(--radius-lg);
    transition: var(--transition);
  }

  .reason-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primary);
  }

  .icon-orb {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(110, 231, 183, 0.1);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-4);
  }

  .icon-orb svg {
    width: 24px;
    height: 24px;
  }

  .reason-card h4 {
    margin-bottom: var(--spacing-2);
    font-size: 1.125rem;
  }

  .reason-card p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  @media (max-width: 900px) {
    .split-layout {
      grid-template-columns: 1fr;
    }
    .content-half {
      order: -1;
      text-align: center;
    }
  }

  @media (max-width: 500px) {
    .grid-half {
      grid-template-columns: 1fr;
    }
  }
</style>
